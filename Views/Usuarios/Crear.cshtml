@model Personal_Sitios.ViewModels.UsuarioViewModel

@{
    ViewData["Title"] = "Formulario Usuario";
}

<form method="post">

    <div class="form-action-panel">
        <a asp-action="Index"
           class="action-circle"
           title="Regresar">
            <i class="fas fa-arrow-left"></i>
        </a>

        <button type="submit"
                class="action-circle"
                title="Guardar">
            <i class="fas fa-save"></i>
        </button>
    </div>

    <div class="form-card card">

        <div class="crud-card-header">
            <h4 class="crud-card-title">
                Formulario Usuario
            </h4>
        </div>

        <div class="card-body">

            <div class="mb-3">
                <label class="form-label">Nombre de usuario</label>
                <input asp-for="usuario" class="form-control" />
                <span asp-validation-for="usuario" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Nombre completo</label>
                <input asp-for="nombre_completo" class="form-control" />
                <span asp-validation-for="nombre_completo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Correo</label>
                <input asp-for="correo" class="form-control" />
                <span asp-validation-for="correo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <input asp-for="password" type="password" class="form-control" />
                <span asp-validation-for="password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Estado</label>

                <select asp-for="estado" class="form-select">
                    <option value="ACTIVO">ACTIVO</option>
                    <option value="INACTIVO">INACTIVO</option>
                    <option value="BLOQUEADO">BLOQUEADO</option>
                </select>

                <span asp-validation-for="estado" class="text-danger"></span>
            </div>

            <div class="mb-4">

                <h5 class="form-section-title">
                    Roles asociados
                </h5>

                <div class="row">

                    @foreach (var rol in Model.RolesDisponibles)
                    {
                        <div class="col-md-4 mb-2">

                            <div class="form-check">

                                <input type="checkbox"
                                       name="RolesSeleccionados"
                                       value="@rol.id_rol"
                                       class="form-check-input" />

                                <label class="form-check-label">
                                    @rol.nombre
                                </label>

                            </div>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

</form>