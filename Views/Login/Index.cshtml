@model Personal_Sitios.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Inicio de Sesión";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-4">

            <div class="crud-card card">

                <div class="crud-card-header text-center">
                    <h4 class="crud-card-title">
                        Inicio de Sesión
                    </h4>
                </div>

                <div class="card-body">

                    @if (ViewBag.Mensaje != null)
                    {
                        <div class="alert alert-success">
                            @ViewBag.Mensaje
                        </div>
                    }

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Error
                        </div>
                    }

                    <form method="post">

                        <div class="mb-3">
                            <label class="form-label">
                                Usuario
                            </label>

                            <input asp-for="Usuario"
                                   class="form-control" />

                            <span asp-validation-for="Usuario"
                                  class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                Contraseña
                            </label>

                            <input asp-for="Password"
                                   type="password"
                                   class="form-control" />

                            <span asp-validation-for="Password"
                                  class="text-danger"></span>
                        </div>

                        <button type="submit"
                                class="btn btn-primary w-100">
                            Aceptar
                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>