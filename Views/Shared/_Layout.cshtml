@{
    var nombreUsuario = Context.Session.GetString("NombreCompleto");
    var usuario = Context.Session.GetString("Usuario");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Personal Sitios</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />

    <link rel="stylesheet"
          href="~/css/personal-sitios.css"
          asp-append-version="true" />
</head>

<body>

    @if (!string.IsNullOrEmpty(nombreUsuario))
    {
        <div class="container-fluid">
            <div class="row">

                <aside class="col-md-3 col-lg-2 sidebar p-3">

                    <div class="text-white mb-4">
                        <h4 class="sidebar-title mb-0">
                            <i class="fas fa-users"></i>
                            Personal Sitios
                        </h4>

                        <small class="sidebar-subtitle">
                            Administración de Personal
                        </small>
                    </div>

                    <ul class="nav flex-column">
                        @await Component.InvokeAsync("Menu")
                    </ul>

                </aside>

                <main class="col-md-9 col-lg-10 p-0">

                    <nav class="topbar d-flex justify-content-between align-items-center px-4">

                        <div class="page-title">
                            @ViewData["Title"]
                        </div>

                        <div class="d-flex align-items-center gap-3">

                            <div class="text-end">
                                <div class="fw-bold">
                                    @nombreUsuario
                                </div>

                                <small class="text-muted">
                                    @usuario
                                </small>
                            </div>

                            <div class="avatar">
                                @nombreUsuario.Substring(0, 1).ToUpper()
                            </div>

                            <a asp-controller="Login"
                                   asp-action="Logout"
                                   class="btn btn-outline-danger btn-sm">
                                <i class="fas fa-sign-out-alt"></i>
                                Salir
                            </a>

                        </div>

                    </nav>

                    <div class="content-wrapper">
                        @RenderBody()
                    </div>

                </main>

            </div>
        </div>
    }
    else
    {
        <main>
            @RenderBody()
        </main>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>