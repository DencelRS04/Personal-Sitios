@model Personal_Sitios.ViewModels.RolViewModel

@{
    ViewData["Title"] = "Formulario Rol";
}

<form method="post">

    <div class="form-action-panel">
        <a asp-action="Index"
               class="action-circle"
               title="Regresar">
            <i class="fas fa-arrow-left"></i>
        </a>

        <button type="submit"
                class="action-circle"
                title="Guardar">
            <i class="fas fa-save"></i>
        </button>
    </div>

    <div class="form-card card">

        <div class="crud-card-header">
            <h4 class="crud-card-title">
                Formulario Rol
            </h4>
        </div>

        <div class="card-body">

            <div class="mb-3">
                <label class="form-label">
                    Nombre del rol
                </label>

                <input asp-for="nombre"
                       class="form-control"
                       maxlength="40" />

                <span asp-validation-for="nombre"
                      class="text-danger"></span>
            </div>

            <div class="mb-4">

                <h5 class="form-section-title">
                    Opciones de menú asociadas
                </h5>

                <div class="row">

                    @foreach (var pantalla in Model.PantallasDisponibles)
                    {
                        <div class="col-md-4 mb-2">

                            <div class="form-check">

                                <input type="checkbox"
                                       name="PantallasSeleccionadas"
                                       value="@pantalla.id_pantalla"
                                       class="form-check-input" />

                                <label class="form-check-label">
                                    @pantalla.nombre
                                </label>

                            </div>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

</form>