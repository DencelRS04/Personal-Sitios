@model Personal_Sitios.ViewModels.PantallaViewModel

@{
    ViewData["Title"] = "Formulario Pantalla";
}

<form method="post">

    <div class="form-action-panel">
        <a asp-action="Index"
           class="action-circle"
           title="Regresar">
            <i class="fas fa-arrow-left"></i>
        </a>

        <button type="submit"
                class="action-circle"
                title="Guardar">
            <i class="fas fa-save"></i>
        </button>
    </div>

    <div class="form-card card">

        <div class="crud-card-header">
            <h4 class="crud-card-title">
                Formulario Pantalla
            </h4>
        </div>

        <div class="card-body">

            <input type="hidden"
                   asp-for="id_pantalla" />

            <div class="mb-3">
                <label class="form-label">
                    Nombre de la pantalla
                </label>

                <input asp-for="nombre"
                       class="form-control"
                       maxlength="100" />

                <span asp-validation-for="nombre"
                      class="text-danger"></span>
            </div>

            <div class="mb-4">

                <h5 class="form-section-title">
                    Roles asociados
                </h5>

                <div class="row">

                    @foreach (var rol in Model.RolesDisponibles)
                    {
                        bool seleccionado =
                            Model.RolesSeleccionados.Contains(rol.id_rol);

                        <div class="col-md-4 mb-2">

                            <div class="form-check">

                                <input type="checkbox"
                                       name="RolesSeleccionados"
                                       value="@rol.id_rol"
                                       class="form-check-input"
                                       checked="@seleccionado" />

                                <label class="form-check-label">
                                    @rol.nombre
                                </label>

                            </div>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

</form>